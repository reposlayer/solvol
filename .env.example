# Optional: enables structured entity extraction + richer narratives (server-side only)
OPENAI_API_KEY=

# Supabase research cloud (run supabase/schema.sql first)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Set true once auth is wired in UI; false allows demo-mode API exploration.
SUPABASE_REQUIRE_AUTH=false
SOLVOL_DEMO_USER_ID=00000000-0000-4000-8000-000000000001

# Snapshot cron: POST /api/internal/snapshot with Authorization: Bearer <secret>
SNAPSHOT_CRON_SECRET=
# Optional path for SQLite (default: ./data/solvol.db)
SQLITE_PATH=
# Set to true to disable DB + feed (e.g. serverless without native module)
SQLITE_DISABLED=false
