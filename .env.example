# Optional: enables structured entity extraction + richer narratives (server-side only)
OPENAI_API_KEY=
FRED_API_KEY=
ALPHA_VANTAGE_API_KEY=

# Supabase research cloud (run supabase/schema.sql first)
NEXT_PUBLIC_SUPABASE_URL=
# Preferred new public key name. NEXT_PUBLIC_SUPABASE_ANON_KEY remains supported.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Optional: stores immutable raw source payload envelopes in Supabase Storage for replay/audit.
SOLVOL_RAW_STORAGE_BUCKET=terminal-raw
# Production invite-only beta must be true. False allows local demo-mode API exploration.
SUPABASE_REQUIRE_AUTH=false
SOLVOL_DEMO_USER_ID=00000000-0000-4000-8000-000000000001

# Snapshot cron: POST /api/internal/snapshot with Authorization: Bearer <secret>
SNAPSHOT_CRON_SECRET=
SOLVOL_INGEST_SECRET=
# Optional Vercel Cron auth header secret for GET /api/internal/ingest.
CRON_SECRET=
# Optional bridge infrastructure and observability settings for staging/canary.
SOLVOL_BRIDGE_REDIS_URL=
SOLVOL_BRIDGE_BROADCASTER_URL=
SOLVOL_ERROR_MONITORING_DSN=
SOLVOL_METRICS_DSN=
SOLVOL_ALERT_ROUTING_URL=
SOLVOL_DEPLOY_TARGET=
SOLVOL_POSTGRES_BACKUP_VERIFIED=false
SOLVOL_SOURCE_POLICY_REVIEWED=false
SOLVOL_SECRET_ROTATION_VERIFIED=false
SOLVOL_CANARY_OWNER=
SOLVOL_CANARY_REVIEWER=
SOLVOL_ROLLBACK_APPROVER=
SOLVOL_STAGING_SHADOW_SOAK_PASSED=false
SOLVOL_REPLAY_DETERMINISM_VERIFIED=false
SOLVOL_ANALYST_QA_APPROVED=false
SOLVOL_CANARY_WINDOW_PASSED=false
SOLVOL_NO_P1_P2_DEFECTS=false
# Optional: enables live Federal Reserve monetary policy RSS polling in the terminal ingestion bridge.
SOLVOL_TERMINAL_FED_RSS_URL=https://www.federalreserve.gov/feeds/press_monetary.xml
# Optional: enables live SEC EDGAR RSS polling. SEC fair-access policy requires a descriptive User-Agent.
SOLVOL_TERMINAL_SEC_RSS_URL=https://www.sec.gov/cgi-bin/browse-edgar?action=getcurrent&type=8-K&output=atom
SOLVOL_TERMINAL_SEC_USER_AGENT=
# Optional: enables market-led GDELT DOC polling in the terminal ingestion bridge.
SOLVOL_TERMINAL_GDELT_ENABLED=false
SOLVOL_TERMINAL_GDELT_LIMIT=30
# Optional: enables live USGS GeoJSON earthquake feed polling in the terminal ingestion bridge.
SOLVOL_TERMINAL_USGS_URL=https://earthquake.usgs.gov/earthquakes/feed/v1.0/summary/all_hour.geojson
# Optional: enables live CISA cybersecurity advisory RSS polling in the terminal ingestion bridge.
SOLVOL_TERMINAL_CISA_RSS_URL=https://www.cisa.gov/cybersecurity-advisories/all.xml
# Optional: enables read-only Ethereum JSON-RPC log polling. Configure at least one contract or topic filter.
SOLVOL_TERMINAL_ETHEREUM_RPC_URL=
SOLVOL_TERMINAL_ETHEREUM_CONTRACTS=
SOLVOL_TERMINAL_ETHEREUM_TOPICS=
SOLVOL_TERMINAL_ETHEREUM_FROM_BLOCK=
SOLVOL_TERMINAL_ETHEREUM_MAX_BLOCK_RANGE=100
# Optional: enables read-only Etherscan indexed log enrichment. JSON-RPC remains the correctness source.
SOLVOL_TERMINAL_ETHERSCAN_API_KEY=
SOLVOL_TERMINAL_ETHERSCAN_CONTRACTS=
SOLVOL_TERMINAL_ETHERSCAN_TOPICS=
SOLVOL_TERMINAL_ETHERSCAN_FROM_BLOCK=
SOLVOL_TERMINAL_ETHERSCAN_MAX_BLOCK_RANGE=100
# Optional: enables read-only FEMA/OpenFEMA IPAWS archived alert polling.
SOLVOL_TERMINAL_FEMA_IPAWS_URL=https://www.fema.gov/api/open/v1/IpawsArchivedAlerts
# Optional: enables low-trust social source polling. Keep disabled until source policy/deletion handling is approved.
SOLVOL_TERMINAL_REDDIT_ACCESS_TOKEN=
SOLVOL_TERMINAL_REDDIT_TERMS=
SOLVOL_TERMINAL_MASTODON_INSTANCE_URL=
SOLVOL_TERMINAL_MASTODON_ACCESS_TOKEN=
SOLVOL_TERMINAL_MASTODON_TERMS=
# Optional: enables commercial news recall adapters from market-led query packs. Keep keys server-side.
SOLVOL_TERMINAL_GNEWS_API_KEY=
SOLVOL_TERMINAL_GNEWS_TERMS=
SOLVOL_TERMINAL_GNEWS_LANGUAGE=en
SOLVOL_TERMINAL_MEDIASTACK_API_KEY=
SOLVOL_TERMINAL_MEDIASTACK_TERMS=
SOLVOL_TERMINAL_MEDIASTACK_LANGUAGES=en
SOLVOL_TERMINAL_MEDIASTACK_COUNTRIES=
SOLVOL_TERMINAL_MEDIASTACK_CATEGORIES=
# Optional: enables read-only fact-check RSS overlays.
SOLVOL_TERMINAL_FACT_CHECK_RSS_URL=
# Optional: enables live CoinGecko public market context polling in the terminal ingestion bridge.
SOLVOL_TERMINAL_COINGECKO_ENABLED=false
SOLVOL_TERMINAL_COINGECKO_IDS=
# Terminal bridge roadmap feature flags. Core feature flags can be enabled independently
# from live source credentials, and source flags gate bridge ingestion by source id.
SOLVOL_FLAG_BRIDGE_CLUSTER_V1=true
SOLVOL_FLAG_BRIDGE_CORRELATION_WHY_MOVED_V1=true
SOLVOL_FLAG_BRIDGE_REALTIME_SSE=true
SOLVOL_FLAG_BRIDGE_UI_PROVENANCE_PANEL=true
SOLVOL_FLAG_BRIDGE_SOCIAL_LOW_TRUST_SOURCES=false
SOLVOL_FLAG_BRIDGE_INGEST_SOURCE_GDELT_DOC=false
SOLVOL_FLAG_BRIDGE_INGEST_SOURCE_SEC_RSS=false
SOLVOL_FLAG_BRIDGE_INGEST_SOURCE_FEDERAL_RESERVE_RSS=false
SOLVOL_FLAG_BRIDGE_INGEST_SOURCE_USGS_EARTHQUAKES=false
SOLVOL_FLAG_BRIDGE_INGEST_SOURCE_CISA_RSS=false
SOLVOL_FLAG_BRIDGE_INGEST_SOURCE_ETHEREUM_JSON_RPC=false
SOLVOL_FLAG_BRIDGE_INGEST_SOURCE_ETHERSCAN_INDEXED=false
SOLVOL_FLAG_BRIDGE_INGEST_SOURCE_COINGECKO_CONTEXT=false
SOLVOL_FLAG_BRIDGE_INGEST_SOURCE_FEMA_IPAWS_RSS=false
SOLVOL_FLAG_BRIDGE_INGEST_SOURCE_REDDIT_OAUTH=false
SOLVOL_FLAG_BRIDGE_INGEST_SOURCE_MASTODON_PUBLIC=false
SOLVOL_FLAG_BRIDGE_INGEST_SOURCE_GNEWS_API=false
SOLVOL_FLAG_BRIDGE_INGEST_SOURCE_MEDIASTACK_API=false
SOLVOL_FLAG_BRIDGE_INGEST_SOURCE_FACT_CHECK_OVERLAYS=false
# Optional path for SQLite (default: ./data/solvol.db)
SQLITE_PATH=
# Set to true to disable DB + feed (e.g. serverless without native module)
SQLITE_DISABLED=false
